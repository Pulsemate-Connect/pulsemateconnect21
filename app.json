{
  "expo": {
    "name": "PulseMate Connect",
    "slug": "pulsemate-app",
    "version": "1.0.8",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#2563EB",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563EB"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "in.pulsemateconnect.patient"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#2563EB"
      },
      "package": "in.pulsemateconnect.patient",
      "versionCode": 13,
      "targetSdkVersion": 34,
      "googleServicesFile": "./google-services.json",
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "com.google.android.gms.permission.AD_ID"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "pulsemate",
    "plugins": [
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "PulseMate uses your location to find nearby clinics and doctors.",
          "locationWhenInUsePermission": "PulseMate uses your location to find nearby clinics and doctors."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0EA5E9",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "PulseMate Connect"
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://api.pulsemateconnect.in/api",
      "apiUrlProd": "https://api.pulsemateconnect.in/api",
      "eas": {
        "projectId": "dc7f9afd-2b0f-4eb0-88f8-7ac7865edbd3"
      }
    },
    "owner": "shubhamskkk"
  }
}
