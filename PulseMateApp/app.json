{
  "expo": {
    "name": "PulseMate Connect",
    "slug": "pulsemate-app",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#2563EB",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563EB"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "in.pulsemateconnect.app",
      "infoPlist": {
        "NSCameraUsageDescription": "PulseMate Connect uses your camera to upload your profile photo.",
        "NSPhotoLibraryUsageDescription": "PulseMate Connect accesses your photo library to set a profile photo.",
        "NSLocationWhenInUseUsageDescription": "PulseMate Connect uses your location to find nearby clinics and doctors."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#2563EB"
      },
      "package": "in.pulsemateconnect.app",
      "versionCode": 3,
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "scheme": "pulsemate",
    "plugins": [
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "PulseMate Connect uses your location to find nearby clinics and doctors.",
          "locationWhenInUsePermission": "PulseMate Connect uses your location to find nearby clinics and doctors."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0EA5E9",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "PulseMate Connect"
        }
      ]
    ],
    "extra": {
      "apiUrl": "http://192.168.31.240:5000/api",
      "apiUrlProd": "https://api.pulsemateconnect.in/api",
      "privacyPolicyUrl": "https://pulsemateconnect.in/privacy-policy",
      "termsUrl": "https://pulsemateconnect.in/terms",
      "eas": {
        "projectId": "dc7f9afd-2b0f-4eb0-88f8-7ac7865edbd3"
      }
    },
    "owner": "shubhamskkk"
  }
}
