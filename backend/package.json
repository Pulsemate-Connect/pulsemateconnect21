{
  "name": "pulsemate-backend",
  "version": "1.0.0",
  "description": "PulseMate Connect Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage --verbose",
    "test:watch": "jest --watch",
    "test:quick": "jest --testPathPattern='dashboard|notification|booking-control|session-validation' --verbose",
    "test:unit": "jest --testPathPattern='controllers' --verbose",
    "test:integration": "jest --testPathPattern='integration' --verbose"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/config/",
      "/migrations/"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/controllers/**/*.js",
      "src/services/**/*.js",
      "src/routes/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  },
  "keywords": [
    "healthcare",
    "clinic",
    "appointment"
  ],
  "author": "PulseMate Team",
  "license": "MIT",
  "dependencies": {
    "multer": "^2.2.0",
    "uuid": "^14.0.1"
  }
}
