{
  "name": "pulsemate-backend",
  "version": "1.0.0",
  "description": "PulseMate Connect Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --config jest.config.js --coverage --verbose",
    "test:watch": "jest --config jest.config.js --watch",
    "test:queue": "jest --config jest.config.js --testPathPattern='reception|booking|queue|availability' --verbose --no-coverage",
    "test:unit": "jest --config jest.config.js --testPathPattern='unit' --verbose --no-coverage",
    "test:integration": "jest --config jest.config.js --testPathPattern='integration' --verbose --no-coverage"
  },
  "keywords": [
    "healthcare",
    "clinic",
    "appointment"
  ],
  "author": "PulseMate Team",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "1.41.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "firebase-admin": "^13.0.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.3.2",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.16",
    "prisma": "5.22.0",
    "razorpay": "^2.9.4",
    "socket.io": "^4.8.1",
    "twilio": "^5.3.5",
    "uuid": "^11.0.3",
    "winston": "^3.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "jest": "^29.7.0",
    "node-mocks-http": "^1.18.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.0.0"
  }
}
