generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String                @id @default(uuid())
  name                 String?
  mobile               String                @unique
  email                String?               @unique
  role                 UserRole              @default(PATIENT)
  approvalStatus       ApprovalStatus        @default(VERIFIED)
  passwordHash         String?
  rejectionReason      String?
  suspendedReason      String?
  isActive             Boolean               @default(true)
  lastLoginAt          DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  isEmailVerified      Boolean               @default(false)
  isPhoneVerified      Boolean               @default(false)
  freeBookingUsed      Boolean               @default(false)
  freeBookingUsedAt    DateTime?
  /// Firebase UID from Firebase Phone Auth (patients only)
  firebaseUid          String?               @unique
  /// Auth provider used — e.g. FIREBASE_PHONE, EMAIL_PASSWORD (staff)
  authProvider         String?
  /// Set when user requests account deletion. Hard-deleted by cron after 10 days.
  deletionRequestedAt  DateTime?
  createdAdmins            AdminProfile[]              @relation("AdminCreator")
  adminProfile             AdminProfile?
  appointments             Appointment[]               @relation("PatientAppointments")
  auditLogs                AuditLog[]                  @relation("AuditActor")
  clinicStaff              ClinicStaff[]
  ownedClinics             Clinic[]                    @relation("ClinicOwner")
  verifiedClinics          Clinic[]                    @relation("ClinicVerifiedBy")
  doctorProfile            DoctorProfile?
  fcmTokens                FcmToken[]
  notificationReads        NotificationRead[]
  userNotifications        UserNotification[]
  passwordResetTokens      PasswordResetToken[]
  patientProfile           PatientProfile?
  payments                 Payment[]                   @relation("PatientPayments")
  prescriptions            prescriptions[]
  queueItems               QueueItem[]                 @relation("PatientQueueItems")
  createdReceptionists     ReceptionistProfile[]       @relation("OwnerCreatedReceptionists")
  receptionistProfile      ReceptionistProfile?
  refreshTokens            RefreshToken[]
  sessions                 Session[]
  dashboardWidgetPreference DashboardWidgetPreference?
  followUps                FollowUp[]                  @relation("PatientFollowUps")
  createdFollowUps         FollowUp[]                  @relation("FollowUpCreator")
  updatedFollowUps         FollowUp[]                  @relation("FollowUpUpdater")
  cancelledFollowUps       FollowUp[]                  @relation("FollowUpCanceller")

  @@map("users")
}

model PatientProfile {
  id                String    @id @default(uuid())
  userId            String    @unique
  age               Int?
  dob               DateTime?
  gender            String?
  address           String?
  city              String?
  state             String?
  pincode           String?
  emergencyContact  String?
  bloodGroup        String?
  allergies         String?
  existingDiseases  String?
  insuranceProvider String?
  profileCompleted  Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("patient_profiles")
}

model Clinic {
  id                                 String                  @id @default(uuid())
  name                               String
  ownerId                            String
  phone                              String?
  address                            String?
  city                               String?
  state                              String?
  pincode                            String?
  latitude                           Float?
  longitude                          Float?
  isVerified                         Boolean                 @default(false)
  approvalStatus                     ApprovalStatus          @default(PENDING)
  rejectionReason                    String?
  isActive                           Boolean                 @default(true)
  openingTime                        String?
  closingTime                        String?
  openingHours                       String?
  description                        String?
  clinicLicenseDocument              String?
  gstNumber                          String?
  specialties                        String[]
  createdAt                          DateTime                @default(now())
  updatedAt                          DateTime                @updatedAt
  licenseDocumentUrl                 String?
  verifiedById                       String?
  landmark                           String?
  googleMapsLocation                 String?
  submittedAt                        DateTime?
  verifiedAt                         DateTime?
  clinicType                         String?
  doctorCount                        Int?
  clinicLogoUrl                      String?
  clinicCoverImageUrl                String?
  emergencyContactNumber             String?
  alternateEmail                     String?
  consultationModes                  String[]                @default([])
  weeklySchedule                     Json?
  avgConsultationMinutes             Int?
  appointmentSlotMinutes             Int?
  dailyPatientCapacity               Int?
  facilities                         String[]                @default([])
  languagesSpoken                    String[]                @default([])
  paymentMethods                     String[]                @default([])
  insuranceSupported                 String[]                @default([])
  clinicRegistrationNumber           String?
  panNumber                          String?
  medicalEstablishmentCertificateUrl String?
  gstCertificateUrl                  String?
  panCardUrl                         String?
  additionalDocuments                Json?
  ownerMobileVerified                Boolean                 @default(false)
  ownerEmailVerified                 Boolean                 @default(false)
  mobileOtpVerifiedAt                DateTime?
  emailVerifiedAt                    DateTime?
  clinicTypeOther                    String?
  specialtyOther                     String?
  district                           String?
  changesRequestedReason             String?
  adminNotes                         String?
  rejectedById                       String?
  rejectedAt                         DateTime?
  suspendedReason                    String?
  lastResubmittedAt                  DateTime?
  appointments                       Appointment[]
  doctorAvailabilities               DoctorAvailability[]
  doctorClinics                      DoctorClinic[]          @relation("MarketplaceClinic")
  staff                              ClinicStaff[]
  verificationLogs                   ClinicVerificationLog[]
  owner                              User                    @relation("ClinicOwner", fields: [ownerId], references: [id])
  verifiedBy                         User?                   @relation("ClinicVerifiedBy", fields: [verifiedById], references: [id])
  queues                             Queue[]
  receptionistProfiles               ReceptionistProfile[]
  sessions                           ClinicSession[]
  holidays                           ClinicHoliday[]
  dashboardWidgetPreferences         DashboardWidgetPreference[]
  followUps                          FollowUp[]
  followUpSettings                   ClinicFollowUpSettings?

  @@map("clinics")
}

model ClinicVerificationLog {
  id        String   @id @default(uuid())
  clinicId  String
  adminId   String?
  oldStatus String
  newStatus String
  remark    String?
  createdAt DateTime @default(now())
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("clinic_verification_logs")
}

model ClinicStaff {
  id        String    @id @default(uuid())
  clinicId  String
  userId    String
  role      StaffRole
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  clinic    Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clinicId, userId])
  @@map("clinic_staff")
}

model DoctorProfile {
  id                        String               @id @default(uuid())
  userId                    String               @unique
  approvalStatus            ApprovalStatus       @default(PENDING)
  qualification             String?
  specialization            String?
  experienceYears           Int?                 @default(0)
  education                 String?
  consultationFee           Float?               @default(0)
  onlineAvailable           Boolean              @default(false)
  offlineAvailable          Boolean              @default(true)
  bio                       String?
  avgConsultationMins       Int                  @default(10)
  medicalRegistrationNumber String?              @unique
  certificates              Json?
  languagesKnown            String[]
  marketplaceVisible        Boolean              @default(false)
  profileStatus             DoctorProfileStatus  @default(INCOMPLETE)
  verificationStatus        DoctorVerificationStatus @default(NOT_VERIFIED)
  gender                    String?
  licenseNumber             String?
  profileImage              String?
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
  documentUrl               String?
  appointments              Appointment[]
  availabilities            DoctorAvailability[]
  doctorClinics             DoctorClinic[]       @relation("MarketplaceDoctor")
  user                      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  prescriptions             prescriptions[]
  queues                    Queue[]
  followUps                 FollowUp[]

  @@map("doctor_profiles")
}

model ReceptionistProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  assignedClinicId String
  createdByOwnerId String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  assignedClinic   Clinic   @relation(fields: [assignedClinicId], references: [id], onDelete: Cascade)
  createdByOwner   User     @relation("OwnerCreatedReceptionists", fields: [createdByOwnerId], references: [id])
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("receptionist_profiles")
}

model AdminProfile {
  id          String     @id @default(uuid())
  userId      String     @unique
  level       AdminLevel
  createdById String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  createdBy   User?      @relation("AdminCreator", fields: [createdById], references: [id])
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_profiles")
}

model DoctorClinic {
  id                  String             @id @default(uuid())
  doctorId            String
  clinicId            String
  inviteStatus        ClinicInviteStatus @default(PENDING)
  roleAtClinic        String?            @default("CONSULTANT")
  consultationFee     Float?
  availableDays       String[]
  startTime           String?
  endTime             String?
  avgConsultationMins Int                @default(10)
  isActive            Boolean            @default(true)
  joinedAt            DateTime?
  removedAt           DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  /// Follow-up settings for this doctor at this clinic
  followUpEnabled     Boolean            @default(true)
  followUpValidityDays Int               @default(30)
  clinic              Clinic             @relation("MarketplaceClinic", fields: [clinicId], references: [id], onDelete: Cascade)
  doctor              DoctorProfile      @relation("MarketplaceDoctor", fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, clinicId])
  @@map("clinic_doctors")
}

model Appointment {
  id                      String            @id @default(uuid())
  patientId               String
  doctorId                String
  clinicId                String
  sessionId               String?
  appointmentType         AppointmentType   @default(OFFLINE)
  appointmentDate         DateTime
  slotTime                String?
  status                  AppointmentStatus @default(BOOKED)
  queueNumber             Int?
  estimatedWaitMinutes    Int?
  symptoms                String?
  notes                   String?
  /// NEW / FOLLOW_UP — whether this is a new consultation or follow-up
  appointmentKind         AppointmentKind   @default(NEW)
  /// For follow-up appointments: the previous completed appointment this follows up on
  followUpOfAppointmentId String?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  clinic                  Clinic            @relation(fields: [clinicId], references: [id])
  doctor                  DoctorProfile     @relation(fields: [doctorId], references: [id])
  patient                 User              @relation("PatientAppointments", fields: [patientId], references: [id])
  payment                 Payment?
  prescriptions           prescriptions?
  queueItem               QueueItem?
  reminders               ReminderSent[]
  /// Follow-up appointments that reference this appointment as their origin
  followUpAppointments    Appointment[]     @relation("FollowUpChain")
  /// The original appointment this follows up on (self-relation)
  followUpOf              Appointment?      @relation("FollowUpChain", fields: [followUpOfAppointmentId], references: [id])
  /// FollowUp records where this appointment IS the original visit
  followUpRecords         FollowUp[]        @relation("OriginalVisitFollowUps")
  /// FollowUp record where this appointment IS the booked follow-up appointment
  bookedFollowUp          FollowUp?         @relation("BookedFollowUpAppointment")

  @@index([patientId, appointmentDate])
  @@index([doctorId, appointmentDate])
  @@index([clinicId, status, appointmentDate])
  @@index([sessionId])
  @@index([followUpOfAppointmentId])
  @@map("appointments")
}

model Queue {
  id         String        @id @default(uuid())
  clinicId   String
  doctorId   String
  sessionId  String?
  date       DateTime      @db.Date
  status     QueueStatus   @default(ACTIVE)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  queueItems QueueItem[]
  clinic     Clinic        @relation(fields: [clinicId], references: [id])
  doctor     DoctorProfile @relation(fields: [doctorId], references: [id])
  session    ClinicSession? @relation(fields: [sessionId], references: [id])

  @@unique([clinicId, doctorId, date, sessionId])
  @@map("queues")
}

model QueueItem {
  id            String          @id @default(uuid())
  queueId       String
  appointmentId String?         @unique
  patientId     String
  queueNumber   Int
  status        QueueItemStatus @default(WAITING)
  position      Int
  isFollowUp    Boolean         @default(false)
  followUpOf    String?
  calledAt      DateTime?
  completedAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  appointment   Appointment?    @relation(fields: [appointmentId], references: [id])
  patient       User            @relation("PatientQueueItems", fields: [patientId], references: [id])
  queue         Queue           @relation(fields: [queueId], references: [id], onDelete: Cascade)

  @@index([queueId, status])
  @@index([patientId])
  @@map("queue_items")
}

model Session {
  id               String   @id @default(uuid())
  userId           String
  refreshTokenHash String   @unique
  authRole         UserRole
  deviceInfo       String?
  ipAddress        String?
  userAgent        String?
  expiresAt        DateTime
  lastUsedAt       DateTime @default(now())
  isRevoked        Boolean  @default(false)
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, authRole, isRevoked])
  @@map("sessions")
}

model PasswordResetToken {
  id        String               @id @default(uuid())
  userId    String
  tokenHash String               @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime             @default(now())
  purpose   PasswordResetPurpose @default(FORGOT_PASSWORD)
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model OtpVerification {
  id          String     @id @default(uuid())
  mobile      String
  purpose     OtpPurpose @default(LOGIN)
  otpHash     String
  expiresAt   DateTime
  attempts    Int        @default(0)
  verifiedAt  DateTime?
  createdAt   DateTime   @default(now())
  isUsed      Boolean    @default(false)
  maxAttempts Int        @default(5)

  @@index([mobile, purpose, createdAt])
  @@map("otp_verifications")
}

model EmailVerification {
  id          String    @id @default(uuid())
  email       String
  purpose     String    @default("CLINIC_OWNER_REGISTER")
  tokenHash   String    @unique
  expiresAt   DateTime
  attempts    Int       @default(0)
  maxAttempts Int       @default(5)
  isUsed      Boolean   @default(false)
  verifiedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([email, purpose, createdAt])
  @@index([tokenHash])
  @@map("email_verifications")
}

model RefreshToken {
  id              String    @id @default(uuid())
  userId          String
  tokenHash       String    @unique
  jwtId           String?   @unique
  expiresAt       DateTime
  revokedAt       DateTime?
  replacedByToken String?
  deviceInfo      String?
  ipAddress       String?
  createdAt       DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt, expiresAt])
  @@map("refresh_tokens")
}

model Payment {
  id                String        @id @default(uuid())
  appointmentId     String        @unique
  patientId         String
  amount            Float
  status            PaymentStatus @default(PENDING)
  method            PaymentMethod @default(RAZORPAY)
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  appointment       Appointment   @relation(fields: [appointmentId], references: [id])
  patient           User          @relation("PatientPayments", fields: [patientId], references: [id])

  @@index([patientId, createdAt])
  @@index([status, paidAt])
  @@index([razorpayOrderId])
  @@map("payments")
}

model FcmToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("fcm_tokens")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User?    @relation("AuditActor", fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model ReminderSent {
  id            String      @id @default(uuid())
  appointmentId String
  type          String
  sentAt        DateTime    @default(now())
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, type])
  @@map("reminder_sent")
}

model prescriptions {
  id               String        @id @default(uuid())
  appointmentId    String        @unique
  doctorId         String
  patientId        String
  diagnosis        String?
  medicines        Json
  instructions     String?
  followUpDate     DateTime?
  requiresFollowUp Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime
  appointments     Appointment   @relation(fields: [appointmentId], references: [id])
  doctor_profiles  DoctorProfile @relation(fields: [doctorId], references: [id])
  users            User          @relation(fields: [patientId], references: [id])
}

model ClinicSession {
  id                  String      @id @default(uuid())
  clinicId            String
  sessionType         SessionType
  name                String
  startTime           String
  endTime             String
  maxPatients         Int         @default(30)
  avgConsultationMins Int         @default(15)
  enabled             Boolean     @default(true)
  sortOrder           Int         @default(0)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  clinic              Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  queues              Queue[]

  @@unique([clinicId, sessionType])
  @@index([clinicId])
  @@map("clinic_sessions")
}

model ClinicHoliday {
  id          String   @id @default(uuid())
  clinicId    String
  date        DateTime @db.Date
  name        String
  reason      String?
  isRecurring Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  
  @@unique([clinicId, date])
  @@index([clinicId])
  @@index([date])
  @@map("clinic_holidays")
}

enum SessionType {
  MORNING
  AFTERNOON
  EVENING
}

enum UserRole {
  PATIENT
  CLINIC_OWNER
  DOCTOR
  RECEPTIONIST
  SUPER_ADMIN
}

enum ApprovalStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
  UNDER_REVIEW
  CHANGES_REQUIRED
}

enum AdminLevel {
  ROOT
  SUPER_ADMIN
  SUPPORT
  FINANCE
}

enum AppointmentType {
  ONLINE
  OFFLINE
}

enum AppointmentKind {
  NEW
  FOLLOW_UP
}

// ─── Follow-Up Status Lifecycle ──────────────────────────────────────────────
enum FollowUpStatus {
  PENDING    // Created, not yet due
  UPCOMING   // Due soon (within 3 days)
  DUE        // Due today
  OVERDUE    // Past due date, not booked
  BOOKED     // Patient has booked the follow-up appointment
  COMPLETED  // Follow-up visit completed
  CANCELLED  // Cancelled by doctor/receptionist/clinic
}

enum AppointmentStatus {
  PENDING_PAYMENT
  BOOKED
  CHECKED_IN
  IN_QUEUE
  CALLED
  IN_CONSULTATION
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum QueueStatus {
  ACTIVE
  PAUSED
  CLOSED
}

enum QueueItemStatus {
  WAITING
  CALLED
  IN_CONSULTATION
  COMPLETED
  SKIPPED
  CANCELLED
}

enum OtpPurpose {
  LOGIN
  SIGNUP
  RESET_PASSWORD
  VERIFY_MOBILE
  PHONE_VERIFY
  PASSWORD_RESET
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  RAZORPAY
  CASH
  UPI
}

enum StaffRole {
  OWNER
  DOCTOR
  RECEPTIONIST
}

enum ClinicInviteStatus {
  PENDING
  ACCEPTED
  REJECTED
  REMOVED
}

enum PasswordResetPurpose {
  FORGOT_PASSWORD
  SUPER_ADMIN_RESET
}

// ─── Notification Read persistence ───────────────────────────────────────────
// ─── Firebase Phone Verification (clinic owner & doctor registration) ────────
// Holds the server-side proof that a phone number was verified via Firebase
// Phone Auth before the user account was created.  Expires after 15 minutes
// and is marked isUsed once consumed during registration.
model FirebasePhoneVerification {
  id          String   @id @default(uuid())
  mobile      String
  firebaseUid String
  /// CLINIC_OWNER_REGISTER | DOCTOR_REGISTER
  purpose     String
  isUsed      Boolean  @default(false)
  expiresAt   DateTime
  verifiedAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([mobile, purpose])
  @@map("firebase_phone_verifications")
}

// ─── Notification Read persistence ───────────────────────────────────────────
model NotificationRead {
  id             String   @id @default(uuid())
  userId         String
  notificationId String
  readAt         DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationId])
  @@map("notification_reads")
}

// ─── Admin Notification Campaigns ────────────────────────────────────────────
model NotificationCampaign {
  id                 String                   @id @default(uuid())
  title              String
  message            String
  channel            NotificationChannel      @default(IN_APP)
  targetType         NotificationTargetType   @default(ALL_USERS)
  targetCity         String?
  targetState        String?
  targetUserIds      String[]                 @default([])
  status             CampaignStatus           @default(DRAFT)
  scheduledAt        DateTime?
  sentAt             DateTime?
  stoppedAt          DateTime?
  createdByAdminId   String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  userNotifications  UserNotification[]

  @@index([status])
  @@index([channel])
  @@map("notification_campaigns")
}

model UserNotification {
  id          String               @id @default(uuid())
  userId      String
  campaignId  String?
  title       String
  message     String
  channel     NotificationChannel  @default(IN_APP)
  isRead      Boolean              @default(false)
  sentAt      DateTime?
  createdAt   DateTime             @default(now())
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign    NotificationCampaign? @relation(fields: [campaignId], references: [id])

  @@index([userId])
  @@index([campaignId])
  @@map("user_notifications")
}

enum NotificationChannel {
  PUSH
  IN_APP
  PUSH_AND_IN_APP
}

enum NotificationTargetType {
  ALL_USERS
  SELECTED_USERS
  CITY
  STATE
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  PAUSED
  STOPPED
  FAILED
}

enum DoctorProfileStatus {
  INCOMPLETE
  COMPLETE
}

enum DoctorVerificationStatus {
  NOT_VERIFIED
  PENDING
  VERIFIED
  REJECTED
}

model DoctorAvailability {
  id              String        @id @default(uuid())
  doctorId        String
  clinicId        String
  dayOfWeek       Int           // 0 = Sunday, 1 = Monday, ..., 6 = Saturday
  isActive        Boolean       @default(true)
  startTime       String        // HH:MM format (24-hour)
  endTime         String        // HH:MM format (24-hour)
  slotDurationMin Int           @default(15)
  maxPatients     Int           @default(20)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  doctor          DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  clinic          Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  
  @@unique([doctorId, clinicId, dayOfWeek])
  @@index([doctorId])
  @@index([clinicId])
  @@index([dayOfWeek])
  @@map("doctor_availability")
}


model DashboardWidgetPreference {
  id        String   @id @default(uuid())
  userId    String   @unique
  clinicId  String
  widgets   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clinicId])
  @@map("dashboard_widget_preferences")
}

// ─── Clinic-level Follow-Up Settings ─────────────────────────────────────────
model ClinicFollowUpSettings {
  id                  String   @id @default(uuid())
  clinicId            String   @unique
  followUpEnabled     Boolean  @default(true)
  /// Preset options available for doctors/receptionists
  preset7DaysEnabled  Boolean  @default(true)
  preset15DaysEnabled Boolean  @default(true)
  preset30DaysEnabled Boolean  @default(true)
  customDaysEnabled   Boolean  @default(true)
  defaultFollowUpDays Int      @default(15)
  /// Grace period after due date before OVERDUE (days)
  gracePeriodDays     Int      @default(7)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  clinic              Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("clinic_followup_settings")
}

// ─── Follow-Up Record ────────────────────────────────────────────────────────
// An explicit follow-up recommendation created by a doctor or receptionist.
// Always linked to a specific completed visit (originalVisitId).
model FollowUp {
  id                String         @id @default(uuid())
  patientId         String
  clinicId          String
  doctorId          String         // DoctorProfile.id
  originalVisitId   String         // Appointment.id of the completed visit
  followUpDays      Int
  followUpDate      DateTime       // = originalVisit.appointmentDate + followUpDays
  status            FollowUpStatus @default(PENDING)
  note              String?
  /// If patient books a follow-up appointment, link it here
  bookedAppointmentId String?      @unique
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  /// Audit trail
  createdByUserId   String
  createdByRole     String
  updatedByUserId   String?
  cancelledByUserId String?
  cancelledAt       DateTime?
  cancellationReason String?

  patient           User           @relation("PatientFollowUps", fields: [patientId], references: [id])
  clinic            Clinic         @relation(fields: [clinicId], references: [id])
  doctor            DoctorProfile  @relation(fields: [doctorId], references: [id])
  originalVisit     Appointment    @relation("OriginalVisitFollowUps", fields: [originalVisitId], references: [id])
  bookedAppointment Appointment?   @relation("BookedFollowUpAppointment", fields: [bookedAppointmentId], references: [id])
  createdBy         User           @relation("FollowUpCreator", fields: [createdByUserId], references: [id])
  updatedBy         User?          @relation("FollowUpUpdater", fields: [updatedByUserId], references: [id])
  cancelledBy       User?          @relation("FollowUpCanceller", fields: [cancelledByUserId], references: [id])

  @@index([patientId])
  @@index([clinicId])
  @@index([doctorId])
  @@index([originalVisitId])
  @@index([followUpDate])
  @@index([status])
  @@map("follow_ups")
}
